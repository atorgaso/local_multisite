msgstr "Укупно плаћања"

#: src/Infrastructure/WP/Translations/LiteBackendStrings.php:1649
msgid "Closes at"
msgstr "Затвара се у"

#: src/Infrastructure/WP/Translations/LiteBackendStrings.php:1650
